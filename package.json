{
    "name": "@openaip/yaixm-to-geojson",
    "version": "1.16.0",
    "description": "Converts YAIXM to GeoJSON. YAIXM is a simplified version of the FAA/EUROCONTROL Aeronautical Information Exchange Model (AIXM) using YAML.",
    "keywords": [
        "openaip",
        "yaixm",
        "aixm",
        "format",
        "geosjon"
    ],
    "authors": [
        {
            "name": "Stephan Besser",
            "email": "stephan@openaip.net",
            "homepage": "https://www.openaip.net",
            "role": "Lead developer"
        }
    ],
    "engines": {
        "node": ">=24.0.0"
    },
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "default": "./dist/*.js"
        }
    },
    "files": [
        "dist"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openAIP/openaip-yaixm-to-geojson.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    },
    "bugs": {
        "url": "https://github.com/openAIP/openaip-yaixm-to-geojson/issues"
    },
    "homepage": "https://github.com/openAIP/openaip-yaixm-to-geojson#readme",
    "scripts": {
        "test": "vitest run",
        "build": "npm run tsc:clean && npm run tsc:build",
        "tsc:run": "tsc --noEmit",
        "tsc:clean": "tsc --build --clean",
        "tsc:build": "tsc --build",
        "code:check": "npx @biomejs/biome check",
        "code:fix": "npx @biomejs/biome check --write",
        "code:format": "npx @biomejs/biome format --write",
        "code:lint": "npx @biomejs/biome lint",
        "release:patch": "npm version --sign-git-tag patch && git push && git push origin --tags",
        "release:minor": "npm version --sign-git-tag minor && git push && git push origin --tags",
        "release:major": "npm version --sign-git-tag major && git push && git push origin --tags",
        "run-security-audit": "npm audit --omit=dev fix",
        "update-packages": "ncu --target minor --upgrade && npm install",
        "depcheck": "npx depcheck --oneline --skip-missing=true --ignore-patterns=dist,coverage,*.log"
    },
    "dependencies": {
        "@openaip/coordinate-parser": "^0.31.1",
        "@placemarkio/check-geojson": "^0.1.14",
        "@turf/turf": "^7.3.4",
        "ajv": "^8.18.0",
        "ajv-errors": "^3.0.0",
        "yaml": "^2.8.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.7",
        "@types/node": ">=24.12.0",
        "@vitest/coverage-v8": "^4.1.0",
        "commander": "^14.0.3",
        "npm-check-updates": "^19.6.3",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    },
    "comments": {
        "packages": {
            "zod": "Version 4 introduces breaking changes!"
        }
    }
}
